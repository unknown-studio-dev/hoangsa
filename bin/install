#!/usr/bin/env node

import os from "node:os";
import fs from "node:fs";
import path from "node:path";
import crypto from "node:crypto";
import readline from "node:readline";
import { fileURLToPath } from "node:url";
import { createRequire } from "node:module";
import { execSync } from "node:child_process";

const _require = createRequire(import.meta.url);

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Colors
const cyan = "\x1b[36m";
const green = "\x1b[32m";
const yellow = "\x1b[33m";
const dim = "\x1b[2m";
const reset = "\x1b[0m";

// Get version from package.json
const pkg = JSON.parse(
  fs.readFileSync(path.join(__dirname, "..", "package.json"), "utf8"),
);

// Parse args
const args = process.argv.slice(2);
const hasGlobal = args.includes("--global") || args.includes("-g");
const hasLocal = args.includes("--local") || args.includes("-l");
const hasUninstall = args.includes("--uninstall") || args.includes("-u");
const hasMedia = args.includes("--media");
const hasJoke = args.includes("--joke");

/** Resolve global config dir: ~/.claude */
function getGlobalDir() {
  return path.join(os.homedir(), ".claude");
}

const banner = `
${cyan}        ++++++++
         ++++ ++++
             ++
           +++
             ++
               ++         +Hoang Sa+
                 ++
                    ++
                    +++
                    +++       +Truong Sa+
              ++++++
          +++++++
            +++
${reset}
Hoàng Sa ${dim}v${pkg.version}${reset}
  A meta-prompting, context engineering and spec-driven
  development system for Claude Code.
`;

const hasHelp = args.includes("--help") || args.includes("-h");

console.log(banner);

// Show help if requested
if (hasHelp) {
  console.log(
    `  ${yellow}Usage:${reset} npx hoangsa-cc [options]\n\n  ${yellow}Options:${reset}\n    ${cyan}-g, --global${reset}              Install globally (to ~/.claude/)\n    ${cyan}-l, --local${reset}               Install locally (to ./.claude/)\n    ${cyan}    --media${reset}               Include video debugging support (montage/diff)\n    ${cyan}-u, --uninstall${reset}           Uninstall HOANGSA (remove all HOANGSA files)\n    ${cyan}    --joke${reset}                Easter egg 🥚\n    ${cyan}-h, --help${reset}                Show this help message\n\n  ${yellow}Examples:${reset}\n    ${dim}# Interactive install (prompts for location)${reset}\n    npx hoangsa-cc\n\n    ${dim}# Install globally${reset}\n    npx hoangsa-cc --global\n\n    ${dim}# Install with video debugging support${reset}\n    npx hoangsa-cc --global --media\n\n    ${dim}# Install to current project only${reset}\n    npx hoangsa-cc --local\n\n    ${dim}# Uninstall HOANGSA globally${reset}\n    npx hoangsa-cc --global --uninstall\n`,
  );
  process.exit(0);
}

/**
 * Resolve the pre-built hoangsa-cli binary from a platform-specific npm package.
 * Tries @hoangsa-cc/cli-<platform>-<arch> first (published packages), then
 * falls back to the local dev build at cli/target/release/.
 *
 * Returns the resolved binary path, or null if not found.
 */

/** Platform string used in package names: win32 maps to "windows", others pass through. */
function platformPackageName() {
  return process.platform === "win32" ? "windows" : process.platform;
}

function resolvePlatformBinary(wantMedia = false) {
  const platform = process.platform; // 'darwin', 'linux', 'win32'
  const arch = process.arch; // 'x64', 'arm64'
  const ext = platform === "win32" ? ".exe" : "";
  const binaryName = wantMedia ? `hoangsa-cli-media${ext}` : `hoangsa-cli${ext}`;
  const fallbackName = `hoangsa-cli${ext}`; // if media binary not found, fall back to default

  // Only x64 and arm64 have published packages
  if (arch === "x64" || arch === "arm64") {
    const pkgName = `@hoangsa-cc/cli-${platformPackageName()}-${arch}`;
    try {
      const pkgJsonPath = _require.resolve(`${pkgName}/package.json`);
      const pkgDir = path.dirname(pkgJsonPath);
      const binPath = path.join(pkgDir, "bin", binaryName);
      if (fs.existsSync(binPath)) {
        return binPath;
      }
      // If --media requested but media binary not in package, fall back to default
      if (wantMedia) {
        const fallbackPath = path.join(pkgDir, "bin", fallbackName);
        if (fs.existsSync(fallbackPath)) {
          console.log(
            `  ${yellow}⚠${reset} Media binary not found in platform package — using default binary`,
          );
          return fallbackPath;
        }
      }
    } catch (_) {
      // Package not installed — fall through to dev build
    }
  }

  // Fallback: local development build
  const devBinary = path.join(
    __dirname,
    "..",
    "cli",
    "target",
    "release",
    binaryName,
  );
  if (fs.existsSync(devBinary)) {
    return devBinary;
  }
  // Try default dev binary if media not found
  if (wantMedia) {
    const devFallback = path.join(
      __dirname,
      "..",
      "cli",
      "target",
      "release",
      fallbackName,
    );
    if (fs.existsSync(devFallback)) {
      console.log(
        `  ${yellow}⚠${reset} Media binary not found — using default. Build with: npm run build:media`,
      );
      return devFallback;
    }
  }

  return null;
}

/**
 * Legacy agent filenames removed in v2.1 (agents now use commands only).
 * Used by both cleanupLegacy() (install) and uninstall().
 */
const LEGACY_AGENT_FILES = [
  "taste.md",
  "plate.md",
  "serve.md",
  "check.md",
  "fix.md",
  "research.md",
];

/** Read and parse settings.json; return {} on missing/invalid. */
function readSettings(settingsPath) {
  try {
    return JSON.parse(fs.readFileSync(settingsPath, "utf8"));
  } catch {
    return {};
  }
}

/** Write settings.json with 2-space indentation. */
function writeSettings(settingsPath, settings) {
  fs.writeFileSync(settingsPath, JSON.stringify(settings, null, 2) + "\n");
}

/** Get commit attribution from global settings: null=remove, undefined=default, string=custom. */
function getCommitAttribution() {
  const { attribution } = readSettings(
    path.join(getGlobalDir(), "settings.json"),
  );
  if (!attribution || attribution.commit === undefined) return undefined;
  return attribution.commit === "" ? null : attribution.commit;
}

/** Process Co-Authored-By lines: null=remove, undefined=keep, string=replace value. */
function processAttribution(content, attribution) {
  if (attribution === null) {
    // Remove Co-Authored-By lines and the preceding blank line
    return content.replace(/(\r?\n){2}Co-Authored-By:.*$/gim, "");
  }
  if (attribution === undefined) {
    return content;
  }
  // Replace with custom attribution (escape $ to prevent backreference injection)
  const safeAttribution = attribution.replace(/\$/g, "$$$$");
  return content.replace(
    /Co-Authored-By:.*$/gim,
    `Co-Authored-By: ${safeAttribution}`,
  );
}

/** Recursively copy srcDir→destDir, processing attribution in .md files.
 *  Path replacement removed — templates now use $HOANGSA_ROOT with runtime
 *  resolution (local preferred over global), so paths are no longer baked in
 *  at install time. */
function copyWithPathReplacement(srcDir, destDir, attribution) {
  if (fs.existsSync(destDir)) fs.rmSync(destDir, { recursive: true });
  fs.mkdirSync(destDir, { recursive: true });

  for (const entry of fs.readdirSync(srcDir, { withFileTypes: true })) {
    const srcPath = path.join(srcDir, entry.name);
    const destPath = path.join(destDir, entry.name);
    if (entry.isDirectory()) {
      copyWithPathReplacement(srcPath, destPath, attribution);
    } else if (entry.name.endsWith(".md")) {
      let content = fs.readFileSync(srcPath, "utf8");
      content = processAttribution(content, attribution);
      fs.writeFileSync(destPath, content);
    } else {
      fs.copyFileSync(srcPath, destPath);
    }
  }
}

/** Remove commands/hoangsa/ and hoangsa/ directories. Returns count removed. */
function removeDirectories(targetDir) {
  let removed = 0;

  const hoangsaCommandsDir = path.join(targetDir, "commands", "hoangsa");
  if (fs.existsSync(hoangsaCommandsDir)) {
    fs.rmSync(hoangsaCommandsDir, { recursive: true });
    removed++;
    console.log(`  ${green}✓${reset} Removed commands/hoangsa/`);
  }

  const hoangsaDir = path.join(targetDir, "hoangsa");
  if (fs.existsSync(hoangsaDir)) {
    fs.rmSync(hoangsaDir, { recursive: true });
    removed++;
    console.log(`  ${green}✓${reset} Removed hoangsa/`);
  }

  return removed;
}

/** Remove the CommonJS package.json marker ({type:commonjs}) if present. Returns 1 if removed. */
function removeCommonJsMarker(targetDir) {
  const pkgJsonPath = path.join(targetDir, "package.json");
  if (!fs.existsSync(pkgJsonPath)) return 0;
  try {
    if (fs.readFileSync(pkgJsonPath, "utf8").trim() === '{"type":"commonjs"}') {
      fs.unlinkSync(pkgJsonPath);
      return 1;
    }
  } catch {}
  return 0;
}

/** Remove legacy agent files + package.json marker. includePattern=true also removes hoangsa-*.md files. */
function cleanupLegacyAgents(targetDir, includePattern = false) {
  let removed = 0;
  const agentsDir = path.join(targetDir, "agents");
  if (fs.existsSync(agentsDir)) {
    let count = 0;
    for (const file of LEGACY_AGENT_FILES) {
      const fp = path.join(agentsDir, file);
      if (fs.existsSync(fp)) {
        fs.unlinkSync(fp);
        count++;
      }
    }
    if (includePattern) {
      for (const file of fs.readdirSync(agentsDir)) {
        if (file.startsWith("hoangsa-") && file.endsWith(".md")) {
          fs.unlinkSync(path.join(agentsDir, file));
          count++;
        }
      }
    }
    if (count > 0) {
      removed++;
      console.log(`  ${green}✓${reset} Removed ${count} legacy HOANGSA agents`);
    }
  }
  if (removeCommonJsMarker(targetDir)) {
    removed++;
    console.log(`  ${green}✓${reset} Removed HOANGSA package.json`);
  }
  return removed;
}

/** Remove all HOANGSA hooks and statusline from settings.json. Returns true if changed. */
function cleanupHooksFromSettings(settings) {
  let changed = false;

  // Remove statusline
  if (
    settings.statusLine &&
    settings.statusLine.command &&
    settings.statusLine.command.includes("hook statusline")
  ) {
    delete settings.statusLine;
    changed = true;
    console.log(`  ${green}✓${reset} Removed hoangsa statusline from settings`);
  }

  // Remove all HOANGSA hooks (check-update, context-monitor, tracker)
  if (settings.hooks) {
    for (const event of Object.keys(settings.hooks)) {
      const before = settings.hooks[event].length;
      settings.hooks[event] = settings.hooks[event].filter(
        (entry) =>
          !entry._hoangsa_managed &&
          (!Array.isArray(entry.hooks) ||
            !entry.hooks.some(
              (h) => h.command && h.command.includes("hoangsa-cli"),
            )),
      );
      if (settings.hooks[event].length < before) {
        changed = true;
        console.log(
          `  ${green}✓${reset} Removed HOANGSA ${event} hooks from settings`,
        );
      }
      if (settings.hooks[event].length === 0) delete settings.hooks[event];
    }
    if (Object.keys(settings.hooks).length === 0) delete settings.hooks;
  }

  return changed;
}

/** Uninstall HOANGSA: removes all HOANGSA files/hooks, preserves user content. */
function uninstall(isGlobal) {
  const targetDir = isGlobal
    ? getGlobalDir()
    : path.join(process.cwd(), ".claude");

  const locationLabel = isGlobal
    ? targetDir.replace(os.homedir(), "~")
    : targetDir.replace(process.cwd(), ".");

  console.log(
    `  Uninstalling HOANGSA from ${cyan}Claude Code${reset} at ${cyan}${locationLabel}${reset}\n`,
  );

  if (!fs.existsSync(targetDir)) {
    console.log(
      `  ${yellow}⚠${reset} Directory does not exist: ${locationLabel}\n  Nothing to uninstall.\n`,
    );
    return;
  }

  let removedCount =
    removeDirectories(targetDir) + cleanupLegacyAgents(targetDir);

  // Clean up hooks from settings
  const settingsPath = path.join(targetDir, "settings.json");
  if (fs.existsSync(settingsPath)) {
    const settings = readSettings(settingsPath);
    if (cleanupHooksFromSettings(settings)) {
      writeSettings(settingsPath, settings);
      removedCount++;
    }
  }

  if (removedCount === 0) {
    console.log(`  ${yellow}⚠${reset} No hoangsa files found to remove.`);
  }

  console.log(`
  ${green}Done!${reset} hoangsa has been uninstalled from Claude Code.
  Your other files and settings have been preserved.
`);
}

// ──────────────────────────────────────────────────────
// Local Patch Persistence
// ──────────────────────────────────────────────────────

const PATCHES_DIR_NAME = "hoangsa-patches";
const MANIFEST_NAME = "hoangsa-manifest.json";

/** Compute SHA256 hash of a file. */
function fileHash(filePath) {
  const content = fs.readFileSync(filePath);
  return crypto.createHash("sha256").update(content).digest("hex");
}

/** Recursively collect {relPath: sha256} for all files in dir. */
function generateManifest(dir, baseDir = dir) {
  const manifest = {};
  if (!fs.existsSync(dir)) return manifest;
  const entries = fs.readdirSync(dir, { withFileTypes: true });
  for (const entry of entries) {
    const fullPath = path.join(dir, entry.name);
    const relPath = path.relative(baseDir, fullPath).replace(/\\/g, "/");
    if (entry.isDirectory()) {
      Object.assign(manifest, generateManifest(fullPath, baseDir));
    } else {
      manifest[relPath] = fileHash(fullPath);
    }
  }
  return manifest;
}

/** Write file manifest for future modification detection. */
function writeManifest(configDir) {
  const hoangsaDir = path.join(configDir, "hoangsa");
  const commandsDir = path.join(configDir, "commands", "hoangsa");
  const manifest = {
    version: pkg.version,
    timestamp: new Date().toISOString(),
    files: {},
  };

  const addHashes = (dir, prefix) => {
    for (const [rel, hash] of Object.entries(generateManifest(dir))) {
      manifest.files[prefix + rel] = hash;
    }
  };
  addHashes(hoangsaDir, "hoangsa/");
  if (fs.existsSync(commandsDir)) addHashes(commandsDir, "commands/hoangsa/");
  fs.writeFileSync(
    path.join(configDir, MANIFEST_NAME),
    JSON.stringify(manifest, null, 2),
  );
  return manifest;
}

/** Compare files against manifest; back up any user-modified files to hoangsa-patches/. */
function saveLocalPatches(configDir) {
  const manifestPath = path.join(configDir, MANIFEST_NAME);
  if (!fs.existsSync(manifestPath)) return [];

  let manifest;
  try {
    manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
  } catch {
    return [];
  }

  const patchesDir = path.join(configDir, PATCHES_DIR_NAME);
  const modified = [];

  for (const [relPath, originalHash] of Object.entries(manifest.files || {})) {
    const fullPath = path.join(configDir, relPath);
    if (!fs.existsSync(fullPath)) continue;
    const currentHash = fileHash(fullPath);
    if (currentHash !== originalHash) {
      const backupPath = path.join(patchesDir, relPath);
      fs.mkdirSync(path.dirname(backupPath), { recursive: true });
      fs.copyFileSync(fullPath, backupPath);
      modified.push(relPath);
    }
  }

  if (modified.length > 0) {
    const meta = {
      backed_up_at: new Date().toISOString(),
      from_version: manifest.version,
      files: modified,
    };
    fs.writeFileSync(
      path.join(patchesDir, "backup-meta.json"),
      JSON.stringify(meta, null, 2),
    );
    console.log(
      `  ${yellow}i${reset}  Found ${modified.length} locally modified HOANGSA file(s) — backed up to ${PATCHES_DIR_NAME}/`,
    );
    for (const f of modified) {
      console.log(`     ${dim}${f}${reset}`);
    }
  }
  return modified;
}

/** After install, report backed-up patches for user to reapply. */
function reportLocalPatches(configDir) {
  let meta;
  try {
    meta = JSON.parse(
      fs.readFileSync(
        path.join(configDir, PATCHES_DIR_NAME, "backup-meta.json"),
        "utf8",
      ),
    );
  } catch {
    return [];
  }
  if (meta.files && meta.files.length > 0) {
    console.log(
      `\n  ${yellow}Local patches detected${reset} (from v${meta.from_version}):`,
    );
    for (const f of meta.files) console.log(`     ${cyan}${f}${reset}`);
    console.log(
      `\n  Your modifications are saved in ${cyan}${PATCHES_DIR_NAME}/${reset}`,
    );
    console.log("  Manually compare and merge the files if needed.\n");
  }
  return meta.files || [];
}

/** Copy all template files to targetDir (commands, workflows, binary, CHANGELOG, VERSION). */
function copyAllFiles(src, targetDir, attribution, wantMedia = false) {
  const failures = [];
  const hoangsaDestDir = path.join(targetDir, "hoangsa");

  // Claude Code: nested structure in commands/ directory
  const commandsDir = path.join(targetDir, "commands");
  fs.mkdirSync(commandsDir, { recursive: true });

  const hoangsaSrc = path.join(src, "commands", "hoangsa");
  const hoangsaDest = path.join(commandsDir, "hoangsa");
  copyWithPathReplacement(hoangsaSrc, hoangsaDest, attribution);
  if (fs.existsSync(hoangsaDest) && fs.readdirSync(hoangsaDest).length > 0) {
    console.log(`  ${green}✓${reset} Installed commands/hoangsa`);
  } else {
    console.error(`  ${yellow}✗${reset} Failed to install commands/hoangsa`);
    failures.push("commands/hoangsa");
  }

  // Copy workflows with path replacement
  const workflowsSrc = path.join(src, "workflows");
  const workflowsDest = path.join(hoangsaDestDir, "workflows");
  copyWithPathReplacement(workflowsSrc, workflowsDest, attribution);
  if (
    fs.existsSync(workflowsDest) &&
    fs.readdirSync(workflowsDest).length > 0
  ) {
    console.log(`  ${green}✓${reset} Installed hoangsa/workflows`);
  } else {
    console.error(`  ${yellow}✗${reset} Failed to install hoangsa/workflows`);
    failures.push("hoangsa/workflows");
  }

  // Copy worker-rules/ subdirectory (base.md + addons/) into workflows/
  const workerRulesSrc = path.join(src, "workflows", "worker-rules");
  const workerRulesDest = path.join(workflowsDest, "worker-rules");
  if (fs.existsSync(workerRulesSrc)) {
    fs.mkdirSync(path.join(workerRulesDest, "addons"), { recursive: true });
    copyWithPathReplacement(workerRulesSrc, workerRulesDest, attribution);
    console.log(`  ${green}✓${reset} Installed hoangsa/workflows/worker-rules`);
  }

  // Copy skills with path replacement
  const skillsSrc = path.join(src, "skills");
  if (fs.existsSync(skillsSrc)) {
    const skillsDest = path.join(targetDir, "skills");
    copyWithPathReplacement(skillsSrc, skillsDest, attribution);
    if (fs.existsSync(skillsDest) && fs.readdirSync(skillsDest).length > 0) {
      console.log(`  ${green}✓${reset} Installed skills`);
    } else {
      console.error(`  ${yellow}✗${reset} Failed to install skills`);
      failures.push("skills");
    }
  }

  // Copy compiled binary — prefer platform package, fall back to dev build
  const binDestDir = path.join(hoangsaDestDir, "bin");
  fs.mkdirSync(binDestDir, { recursive: true });
  const binaryDestName =
    process.platform === "win32" ? "hoangsa-cli.exe" : "hoangsa-cli";
  const binaryDest = path.join(binDestDir, binaryDestName);
  const resolvedBinary = resolvePlatformBinary(wantMedia);
  if (resolvedBinary) {
    fs.copyFileSync(resolvedBinary, binaryDest);
    fs.chmodSync(binaryDest, 0o755);
    console.log(`  ${green}✓${reset} Installed hoangsa-cli binary`);
  } else {
    console.log(
      `  ${yellow}⚠${reset} Binary not found — run 'npm run build:rust' first or install a platform package`,
    );
    failures.push("hoangsa-cli binary");
  }

  // Copy CHANGELOG.md (optional — skip silently if not present in package)
  const changelogSrc = path.join(__dirname, "..", "CHANGELOG.md");
  const changelogDest = path.join(hoangsaDestDir, "CHANGELOG.md");
  if (fs.existsSync(changelogSrc)) {
    fs.copyFileSync(changelogSrc, changelogDest);
    console.log(`  ${green}✓${reset} Installed CHANGELOG.md`);
  }

  // Write VERSION file
  const versionDest = path.join(hoangsaDestDir, "VERSION");
  fs.writeFileSync(versionDest, pkg.version);
  console.log(`  ${green}✓${reset} Wrote VERSION (${pkg.version})`);

  // Install quality gate skills (external dependencies for cook workflow Step 4d)
  // Skill sources are hardcoded constants — no user input in execSync calls
  const qualitySkills = [
    { source: "paulkinlan/co-do", skill: "silent-failure-hunter" },
    { source: "paulkinlan/co-do", skill: "pr-test-analyzer" },
    { source: "paulkinlan/co-do", skill: "comment-analyzer" },
    { source: "paulkinlan/co-do", skill: "type-design-analyzer" },
  ];
  console.log(`  ${dim}Installing quality gate skills...${reset}`);
  let skillsInstalled = 0;
  for (const { source, skill } of qualitySkills) {
    const skillDir = path.join(os.homedir(), ".claude", "skills", skill);
    if (fs.existsSync(skillDir)) {
      skillsInstalled++;
      continue;
    }
    try {
      execSync(`npx skills add ${source}@${skill} -g -y`, {
        stdio: "pipe",
        timeout: 30000,
      });
      skillsInstalled++;
    } catch {
      console.log(
        `  ${yellow}⚠${reset} Failed to install ${skill} — quality gate will skip this analyzer`,
      );
    }
  }
  if (skillsInstalled > 0) {
    console.log(
      `  ${green}✓${reset} Quality gate skills: ${skillsInstalled}/${qualitySkills.length} ready`,
    );
  }

  return failures;
}

/** Remove .hoangsa/project-memory.json from current project (dead since v2.x — conventions now handled by worker-rules + addons). */
function cleanupProjectMemory() {
  const memoryFile = path.join(
    process.cwd(),
    ".hoangsa",
    "project-memory.json",
  );
  if (fs.existsSync(memoryFile)) {
    fs.unlinkSync(memoryFile);
    console.log(
      `  ${green}✓${reset} Removed deprecated .hoangsa/project-memory.json`,
    );
  }
}

/** Remove legacy artifacts during install (agents + project-memory + hooks from settings). */
function cleanupLegacy(targetDir) {
  cleanupLegacyAgents(targetDir, true);
  cleanupProjectMemory();

  // Remove all legacy HOANGSA hooks from settings.json
  const settingsPath = path.join(targetDir, "settings.json");
  if (fs.existsSync(settingsPath)) {
    const settings = readSettings(settingsPath);
    if (cleanupHooksFromSettings(settings)) {
      writeSettings(settingsPath, settings);
    }
  }
}

/** Install HOANGSA Stop hook into settings.json.
 *  Uses runtime resolution: tries local binary first, falls back to global.
 *  Replaces any existing _hoangsa_managed Stop hook (including legacy prompt-type). */
function ensureHoangsaHooks(settings) {
  if (!settings.hooks) settings.hooks = {};
  if (!settings.hooks.Stop) settings.hooks.Stop = [];

  // Remove any existing _hoangsa_managed Stop hooks (prompt or command type)
  settings.hooks.Stop = settings.hooks.Stop.filter(
    (entry) => !entry._hoangsa_managed,
  );

  // Add the deterministic command-type Stop hook
  settings.hooks.Stop.push({
    _hoangsa_managed: true,
    hooks: [
      {
        type: "command",
        command:
          'sh -c \'h=./.claude/hoangsa/bin/hoangsa-cli;[ -x "$h" ]||h=$HOME/.claude/hoangsa/bin/hoangsa-cli;"$h" hook stop-check\'',
        timeout: 5,
      },
    ],
  });

  console.log(`  ${green}✓${reset} Installed Stop hook (workflow completion guard)`);
  return true;
}

/** Install HOANGSA to global (~/.claude) or local (./.claude) config directory. */
function install(isGlobal) {
  const src = path.join(__dirname, "..", "templates");

  // Resolve paths
  const targetDir = isGlobal
    ? getGlobalDir()
    : path.join(process.cwd(), ".claude");

  const locationLabel = isGlobal
    ? targetDir.replace(os.homedir(), "~")
    : targetDir.replace(process.cwd(), ".");

  console.log(
    `  Installing for ${cyan}Claude Code${reset} to ${cyan}${locationLabel}${reset}\n`,
  );

  // Resolve attribution once — used by copyWithPathReplacement for all .md files
  const attribution = getCommitAttribution();

  // Save any locally modified HOANGSA files before they get wiped
  saveLocalPatches(targetDir);

  // Copy all files
  const failures = copyAllFiles(src, targetDir, attribution, hasMedia);

  // Clean up legacy artifacts
  cleanupLegacy(targetDir);

  if (failures.length > 0) {
    console.error(
      `\n  ${yellow}Installation incomplete!${reset} Failed: ${failures.join(", ")}`,
    );
    process.exit(1);
  }

  // Write file manifest for future modification detection
  writeManifest(targetDir);
  console.log(`  ${green}✓${reset} Wrote file manifest (${MANIFEST_NAME})`);

  // Report any backed-up local patches
  reportLocalPatches(targetDir);

  // Read settings and install HOANGSA hooks
  const settingsPath = path.join(targetDir, "settings.json");
  const settings = readSettings(settingsPath);
  ensureHoangsaHooks(settings);

  // Install Thoth globally (skip if already installed)
  try {
    execSync("thoth --version", { stdio: "pipe" });
    console.log(`  ${green}✓${reset} thoth already installed`);
  } catch {
    try {
      execSync("npx @unknownstudio/thoth", { stdio: "pipe" });
      console.log(`  ${green}✓${reset} Installed thoth`);
    } catch (e) {
      console.log(`  ${yellow}⚠${reset} Could not install thoth: ${e.message}`);
    }
  }

  // Index the project with Thoth
  try {
    execSync("thoth index .", { stdio: "pipe" });
    console.log(`  ${green}✓${reset} Indexed project with thoth`);
  } catch (e) {
    console.log(
      `  ${yellow}⚠${reset} Could not index project with thoth: ${e.message}`,
    );
  }

  return { settingsPath, settings };
}

/** Prompt user to configure a task manager MCP server (ClickUp/Asana), or skip. */
function handleTaskManager(settings, isInteractive, callback) {
  const TASK_MANAGER_MCP = {
    clickup: {
      label: "ClickUp",
      transport: "http",
      url: "https://mcp.clickup.com/mcp",
      env: {},
      envHint: null,
      docUrl: "https://clickup.com/integrations/mcp",
    },
    asana: {
      label: "Asana",
      command: "npx",
      args: ["-y", "mcp-server-asana"],
      env: { ASANA_ACCESS_TOKEN: "" },
      envHint: "ASANA_ACCESS_TOKEN",
      docUrl: "https://github.com/roychri/mcp-server-asana",
    },
  };
  // Skip if already configured
  if (
    settings.mcpServers &&
    Object.keys(settings.mcpServers).some((k) =>
      ["clickup", "asana"].some((p) => k.toLowerCase().includes(p)),
    )
  ) {
    console.log(
      `  ${green}✓${reset} Task manager MCP already configured — skipping`,
    );
    callback(null);
    return;
  }

  if (!isInteractive) {
    console.log(
      `  ${dim}Skipping task manager setup (non-interactive). Run /hoangsa:serve to configure later.${reset}`,
    );
    callback(null);
    return;
  }

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  console.log(`
  ${yellow}Task Manager Integration${reset} ${dim}(for /hoangsa:serve)${reset}

  Sync task status to your project manager via MCP.

  ${cyan}1${reset}) ClickUp
  ${cyan}2${reset}) Asana
  ${cyan}3${reset}) Skip ${dim}(configure later with /hoangsa:serve)${reset}
`);

  rl.question(`  Choice ${dim}[3]${reset}: `, (answer) => {
    rl.close();
    const choice = answer.trim() || "3";
    const providers = ["clickup", "asana"];
    const idx = parseInt(choice, 10) - 1;

    if (idx >= 0 && idx < providers.length) {
      const provider = providers[idx];
      const mcpConfig = TASK_MANAGER_MCP[provider];

      if (!settings.mcpServers) settings.mcpServers = {};
      settings.mcpServers[provider] =
        mcpConfig.transport === "http"
          ? { type: "http", url: mcpConfig.url }
          : {
              command: mcpConfig.command,
              args: mcpConfig.args,
              env: mcpConfig.env,
            };

      console.log(
        `  ${green}✓${reset} Added ${mcpConfig.label} MCP server to settings`,
      );
      if (mcpConfig.envHint) {
        console.log(`  ${yellow}!${reset} Set your API key in settings.json:`);
        console.log(
          `    ${dim}mcpServers.${provider}.env.${mcpConfig.envHint}${reset}`,
        );
      }
      console.log(`    ${dim}Docs: ${mcpConfig.docUrl}${reset}\n`);
      callback(provider);
    } else {
      console.log(
        `  ${dim}Skipped. Run /hoangsa:serve later to configure.${reset}\n`,
      );
      callback(null);
    }
  });
}

/**
 * Chain: task manager setup → write settings → print completion
 */
function runPostInstall(result, isInteractive) {
  handleTaskManager(result.settings, isInteractive, () => {
    writeSettings(result.settingsPath, result.settings);
    console.log(
      `\n  ${green}Done!${reset} Start Claude Code and run ${cyan}/hoangsa:menu${reset} to begin.\n`,
    );
  });
}

/** Prompt user to choose global or local install. */
function promptLocation() {
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  let answered = false;

  rl.on("close", () => {
    if (!answered) {
      answered = true;
      console.log(`\n  ${yellow}Installation cancelled${reset}\n`);
      process.exit(0);
    }
  });

  const globalPath = getGlobalDir().replace(os.homedir(), "~");

  console.log(`  ${yellow}Where would you like to install?${reset}\n\n  ${cyan}1${reset}) Global ${dim}(${globalPath})${reset} - available in all projects
  ${cyan}2${reset}) Local  ${dim}(./.claude)${reset} - this project only
`);

  rl.question(`  Choice ${dim}[1]${reset}: `, (answer) => {
    answered = true;
    rl.close();
    const choice = answer.trim() || "1";
    const isGlobal = choice !== "2";
    const result = install(isGlobal);
    runPostInstall(result, true);
  });
}

const red = "\x1b[31m";

/** If --joke flag is present, ask for user's name first. */
function jokePrompt(callback) {
  if (!hasJoke) return callback();

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  rl.question(`\n  ${cyan}Bạn tên là gì?${reset} `, (name) => {
    rl.close();
    const trimmed = name.trim();
    if (trimmed.toLowerCase().startsWith("h")) {
      console.log(
        `\n  ${red}⚠ CẢNH BÁO:${reset} Những người tên bắt đầu bằng chữ H thì không nên sử dụng tool này! 🙅\n`,
      );
      process.exit(1);
    }
    console.log(`\n  ${green}Chào ${trimmed}!${reset} Tiếp tục cài đặt...\n`);
    callback();
  });
}

// Main logic — skip when running in test mode
if (!process.env.HOANGSA_TEST_MODE) {
  jokePrompt(() => {
    if (hasGlobal && hasLocal) {
      console.error(
        `  ${yellow}Cannot specify both --global and --local${reset}`,
      );
      process.exit(1);
    } else if (hasUninstall) {
      if (!hasGlobal && !hasLocal) {
        console.error(
          `  ${yellow}--uninstall requires --global or --local${reset}`,
        );
        process.exit(1);
      }
      uninstall(hasGlobal);
    } else if (hasGlobal || hasLocal) {
      const isGlobal = hasGlobal;
      const result = install(isGlobal);
      runPostInstall(result, false);
    } else {
      // Interactive
      if (!process.stdin.isTTY) {
        console.log(
          `  ${yellow}Non-interactive terminal detected, defaulting to global install${reset}\n`,
        );
        const result = install(true);
        runPostInstall(result, false);
      } else {
        promptLocation();
      }
    }
  });
}
