#!/usr/bin/env node
// Thin shim: resolve the hoangsa-cli binary and exec `hoangsa-cli install ...`.
// All install logic lives in the Rust crate (see crates/hoangsa-cli/src/cmd/install.rs).
import os from "node:os";
import fs from "node:fs";
import path from "node:path";
import readline from "node:readline";
import { spawnSync } from "node:child_process";
import { fileURLToPath } from "node:url";
import { createRequire } from "node:module";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const _require = createRequire(import.meta.url);
const EXE = process.platform === "win32" ? ".exe" : "";
const BIN = `hoangsa-cli${EXE}`;

function resolveCli() {
  // 1. Global install location (from curl|sh or prior --global run).
  const globalBin = path.join(os.homedir(), ".hoangsa-memory", "bin", BIN);
  if (fs.existsSync(globalBin)) return globalBin;
  // 2. Platform-specific npm package (published as optionalDependencies).
  if (process.arch === "x64" || process.arch === "arm64") {
    const plat = process.platform === "win32" ? "windows" : process.platform;
    try {
      const pkgJson = _require.resolve(`@hoangsa-cc/cli-${plat}-${process.arch}/package.json`);
      const p = path.join(path.dirname(pkgJson), "bin", BIN);
      if (fs.existsSync(p)) return p;
    } catch {}
  }
  // 3. Local dev build at workspace root.
  const dev = path.join(__dirname, "..", "target", "release", BIN);
  if (fs.existsSync(dev)) return dev;
  return null;
}

function maybePromptTaskManager(args, done) {
  const skip = args.some((a) => a === "--dry-run" || a === "--uninstall" || a === "-u" || a.startsWith("--task-manager"));
  if (skip || !process.stdin.isTTY) return done(args);
  const choices = ["clickup", "asana", "linear", "jira", "github", "none"];
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const menu = choices.map((c, i) => `  ${i + 1}) ${c}`).join("\n");
  rl.question(`\nTask manager integration (for /hoangsa:serve):\n${menu}\nChoice [6]: `, (answer) => {
    rl.close();
    const idx = parseInt((answer || "").trim(), 10) - 1;
    const pick = idx >= 0 && idx < choices.length ? choices[idx] : "none";
    done([...args, `--task-manager=${pick}`]);
  });
}

const cli = resolveCli();
if (!cli) {
  console.error("hoangsa-cli binary not found. Install via:");
  console.error("  curl -fsSL https://raw.githubusercontent.com/unknown-studio-dev/hoangsa/master/scripts/install.sh | sh");
  console.error("Or build locally: npm run build");
  process.exit(1);
}

maybePromptTaskManager(process.argv.slice(2), (args) => {
  const r = spawnSync(cli, ["install", ...args], { stdio: "inherit" });
  if (r.error) { console.error(r.error.message); process.exit(1); }
  process.exit(r.status ?? 1);
});
